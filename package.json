{
  "name": "vscode-flux-helm-intellisense",
  "displayName": "Flux Helm IntelliSense",
  "description": "Helm values IntelliSense for Flux HelmRelease spec.values blocks.",
  "version": "1.1.0",
  "publisher": "westtechnologyconsultingab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscarwest/vscode-flux-helm-intellisense.git"
  },
  "bugs": {
    "url": "https://github.com/oscarwest/vscode-flux-helm-intellisense/issues"
  },
  "homepage": "https://github.com/oscarwest/vscode-flux-helm-intellisense#readme",
  "vsce": {
    "baseContentUrl": "https://github.com/oscarwest/vscode-flux-helm-intellisense/blob/main",
    "baseImagesUrl": "https://raw.githubusercontent.com/oscarwest/vscode-flux-helm-intellisense/main"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "keywords": [
    "flux",
    "helm",
    "helmrelease",
    "kubernetes",
    "yaml",
    "intellisense",
    "values"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fluxHelmValues.refreshChartCache",
        "title": "Flux Helm IntelliSense: Refresh Chart Cache"
      },
      {
        "command": "fluxHelmValues.clearChartCache",
        "title": "Flux Helm IntelliSense: Clear Chart Cache"
      },
      {
        "command": "fluxHelmValues.showResolvedChart",
        "title": "Flux Helm IntelliSense: Show Resolved Chart"
      },
      {
        "command": "fluxHelmValues.copyHelmCommand",
        "title": "Flux Helm IntelliSense: Copy Helm Pull Command"
      },
      {
        "command": "fluxHelmValues.showLogs",
        "title": "Flux Helm IntelliSense: Show Logs"
      },
      {
        "command": "fluxHelmValues.checkHelmSetup",
        "title": "Flux Helm IntelliSense: Check Helm Setup"
      }
    ],
    "configuration": {
      "title": "Flux Helm IntelliSense",
      "properties": {
        "fluxHelmValues.helmPath": {
          "type": "string",
          "default": "helm",
          "description": "Path to the Helm executable used to pull chart metadata."
        },
        "fluxHelmValues.cacheTtlHours": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "description": "Number of hours a successfully pulled chart stays fresh in the extension cache."
        },
        "fluxHelmValues.linting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable schema and values.yaml-backed lint warnings for HelmRelease spec.values blocks."
        },
        "fluxHelmValues.repositorySearchPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional files, directories, or glob patterns to scan for Flux HelmRepository manifests after same-file, sibling, and workspace lookup fails."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "package:vsix": "vsce package",
    "release": "semantic-release"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "semantic-release": "^25.0.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
